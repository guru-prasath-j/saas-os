# PersonalOS / Amy config. Copy to .env and fill. Comments on their own line.
PERSONALOS_MODE=personal
AMY_VAULT=..
OPENAI_API_KEY=
AMY_OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
AMY_GROQ_MODEL=llama-3.3-70b-versatile
AMY_PROVIDER_ORDER=openai,groq,ollama
OLLAMA_HOST=http://localhost:11434
AMY_OLLAMA_MODEL=llama3.2
AMY_EMBED_MODEL=nomic-embed-text
AMY_EMBED_BACKEND=ollama
AMY_AUTH_TOKEN=
# Learning feed (MCP-connector-backed; register sources via /api/mcp/connectors)
AMY_LEARNING_FOCUS=generative AI
AMY_LEARNING_FEED_ENABLED=false
